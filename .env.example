# =========================================================
# Application
# =========================================================
# Local app origin. Used by site config and Supabase auth redirects.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =========================================================
# Supabase
# =========================================================
# Project URL — Supabase Dashboard → Project Settings → API → Project URL
# Local Supabase (optional): http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_URL=

# Anon / public key — Supabase Dashboard → Project Settings → API → Project API keys → anon public
# Local Supabase (optional): npx supabase status → anon key
NEXT_PUBLIC_SUPABASE_ANON_KEY=
