# =========================================================
# Application
# =========================================================
# Local app origin. Used by site config and Supabase auth redirects.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =========================================================
# Supabase
# =========================================================
# Project URL — Supabase Dashboard → Project Settings → API → Project URL
# Local Supabase (optional): http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_URL=

# Anon / public key — Supabase Dashboard → Project Settings → API → Project API keys → anon public
# Local Supabase (optional): npx supabase status → anon key
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only service role key — required for HR employee account invitations,
# password resets, suspensions, and activation via Supabase Auth Admin APIs.
# Never expose this value to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# =========================================================
# Email (SMTP) — transactional mail + Universal Email Approval Engine
# =========================================================
# Sender identity used for all outbound HRMS emails.
EMAIL_FROM="iFranchise HRMS <contact@ifranchise.in>"

# SMTP credentials. Email delivery is disabled (logged & skipped) until
# SMTP_HOST + SMTP_PASSWORD are provided.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# SMTP_SECURE=true   # set when using port 465

# Optional: dedicated HMAC secret + single-use link lifetime for approval tokens.
# APPROVAL_TOKEN_SECRET=
# APPROVAL_TOKEN_TTL_HOURS=48
